# ============================================================================
# STREAMLIT CLOUD DEPLOYMENT: Important!
# ============================================================================
# For Streamlit Cloud deployment, we NEED to commit:
# - models/ folder (trained models)
# - generated_data/ folder (training data)
#
# The patterns below ONLY ignore local/dev files, NOT production files
# ============================================================================

# Models: Keep trained models for production deployment
# Only ignore models/.gitkeep (we want actual model files)
models/.gitkeep

# Generated Data: Keep production datasets for deployment
# Only ignore demo/test datasets locally, keep production datasets (yards only)
generated_data/*demo*.csv
generated_data/*demo*.txt

# Ignore all meters datasets
generated_data/*meters*.csv
generated_data/*meters*.txt

# Keep yards datasets for deployment
!generated_data/production_*yards*.csv
!generated_data/production_*yards*.txt
!generated_data/training_*yards*.csv
!generated_data/training_*yards*.txt
!generated_data/demo_*yards*.csv
!generated_data/batch_prediction_template.csv

# Ignore other CSV/JSON files in root (but allow in generated_data/)
*.csv
*.xlsx
*.json
!generated_data/*.csv
!generated_data/*.json
!model_metadata.json
!package.json
